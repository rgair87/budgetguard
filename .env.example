# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/budgetguard
DB_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Auth
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Plaid
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=https://your-domain.com/api/plaid/webhooks

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@budgetguard.com

# App
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:5173
MOBILE_SCHEME=budgetguard
