{
  "name": "runway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @runway/server dev",
    "dev:web": "pnpm --filter @runway/web dev",
    "build": "pnpm --filter @runway/shared build && pnpm --filter @runway/web build",
    "db:init": "pnpm --filter @runway/server db:init",
    "db:seed": "pnpm --filter @runway/server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3"]
  }
}
