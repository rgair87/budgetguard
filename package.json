{
  "name": "budgetguard",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered personal finance management app",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:server": "turbo dev --filter=@budgetguard/server",
    "dev:web": "turbo dev --filter=@budgetguard/web",
    "dev:mobile": "turbo dev --filter=@budgetguard/mobile",
    "db:migrate": "pnpm --filter @budgetguard/server db:migrate",
    "db:seed": "pnpm --filter @budgetguard/server db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  }
}
